DEVPORTS_PROJECT_NAME=art-installation

# Port allocations
RUNTIME_PORT=5006
GALLERY_PORT=3002
GALLERY_FRONTEND_PORT=5005

# Derived URLs (use allocated ports)
VITE_GALLERY_URL=http://localhost:5005
VITE_GALLERY_API_URL=http://localhost:3002/api
VITE_RUNTIME_URL=http://localhost:5006
RUNTIME_URL=http://localhost:5006

# Gallery Server Configuration
GALLERY_DATA_DIR=./data
ANTHROPIC_API_KEY=
GALLERY_MAX_ARTWORKS=30
GALLERY_PRUNE_PERCENTAGE=0.1
GALLERY_MIN_SCORE=40

# Runtime ID gating
GALLERY_SAMPLE_RUNTIME_ID=
GALLERY_OFFICIAL_RUNTIME_ID=

# Coolify deployment server (see CLAUDE.md § Deployment)
COOLIFY_SERVER_IP=
