# Gallery Server Configuration
GALLERY_PORT=3001
GALLERY_DATA_DIR=./data

# OpenRouter API for AI artwork reviews (leave empty for mock reviews)
OPENROUTER_API_KEY=

# Artwork management
GALLERY_MAX_ARTWORKS=100
GALLERY_PRUNE_PERCENTAGE=0.1
GALLERY_MIN_SCORE=40

# Runtime ID gating (both empty = allow all submissions)
GALLERY_SAMPLE_RUNTIME_ID=
GALLERY_OFFICIAL_RUNTIME_ID=

# CORS - Runtime URL
RUNTIME_URL=http://localhost:3000

# Frontend Configuration (optional)
# VITE_API_URL=/api
# VITE_USE_MOCK_API=false

# Buzz sources (social media monitoring for art installation)
RAPIDAPI_KEY=              # Optional: RapidAPI key for Twitter/X search
RAPIDAPI_TWITTER_HOST=     # Optional: RapidAPI host for Twitter provider (e.g., twitter-api45.p.rapidapi.com)
BLUESKY_IDENTIFIER=        # Optional: Bluesky handle or email for authenticated search
BLUESKY_PASSWORD=          # Optional: Bluesky app password
MATTERMOST_URL=            # Optional: Mattermost instance URL
MATTERMOST_TOKEN=          # Optional: Mattermost bot/personal token
MATTERMOST_CHANNEL_IDS=    # Optional: comma-separated channel IDs
BUZZ_POLL_INTERVAL=300000  # Polling interval in ms (default: 5 min)
