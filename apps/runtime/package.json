{
  "name": "@art/runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Main runtime application for the art installation",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:visual": "vitest run --project visual --browser.enabled",
    "test:perf": "vitest run --project performance --browser.enabled",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@art/types": "workspace:*",
    "pixi-filters": "^6.1.5",
    "pixi.js": "^8.6.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.5",
    "@vitest/browser": "^2.1.0",
    "msw": "^2.7.0",
    "playwright": "^1.49.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
