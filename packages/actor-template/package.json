{
  "name": "@art/actor-template",
  "version": "0.1.0",
  "private": true,
  "description": "Template for creating new actors",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "vite preview/",
    "dev:debug": "ACTOR_DEBUG=true vite preview/",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "actor-validate src/index.ts",
    "validate:full": "actor-validate src/index.ts --performance --isolation",
    "profile": "actor-profile src/index.ts --duration=10"
  },
  "dependencies": {
    "@art/types": "workspace:*",
    "@art/actor-sdk": "workspace:*"
  },
  "devDependencies": {
    "@art/actor-devtools": "workspace:*",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
